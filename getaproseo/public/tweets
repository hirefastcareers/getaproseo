<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tweet Manager — GetAProSEO</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --teal: #0d9488;
    --teal-dark: #0a7a70;
    --black: #0a0a0a;
    --white: #ffffff;
    --card: #141414;
    --card-posted: #0f0f0f;
    --border: #222;
    --border-light: #2a2a2a;
    --mid: #666;
    --light: #aaa;
    --green: #16a34a;
    --red: #ef4444;
    --blue: #2563eb;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--black);
    color: var(--white);
    min-height: 100vh;
  }

  /* LOCK SCREEN */
  #lock-screen {
    position: fixed;
    inset: 0;
    background: var(--black);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 24px;
  }

  .lock-card {
    background: #141414;
    border: 1px solid var(--border-light);
    border-radius: 20px;
    padding: 48px 40px;
    text-align: center;
    max-width: 400px;
    width: 100%;
  }

  .lock-icon {
    font-size: 40px;
    margin-bottom: 20px;
  }

  .lock-card h2 {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 900;
    margin-bottom: 8px;
  }

  .lock-card p {
    color: var(--mid);
    font-size: 14px;
    margin-bottom: 28px;
  }

  .lock-input {
    width: 100%;
    background: #0a0a0a;
    border: 1.5px solid var(--border-light);
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 16px;
    font-family: inherit;
    color: var(--white);
    outline: none;
    margin-bottom: 12px;
    transition: border-color 0.2s;
    text-align: center;
    letter-spacing: 3px;
  }

  .lock-input:focus { border-color: var(--teal); }

  .lock-btn {
    width: 100%;
    background: var(--teal);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 14px;
    font-size: 15px;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.2s;
  }

  .lock-btn:hover { background: var(--teal-dark); }

  .lock-error {
    color: var(--red);
    font-size: 13px;
    margin-top: 10px;
    display: none;
  }

  /* NAV */
  nav {
    background: rgba(10,10,10,0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 900;
    color: var(--white);
    text-decoration: none;
  }

  .nav-logo span { color: var(--teal); }

  .nav-badge {
    font-size: 11px;
    font-weight: 700;
    color: var(--teal);
    background: rgba(13,148,136,0.1);
    border: 1px solid rgba(13,148,136,0.3);
    border-radius: 20px;
    padding: 4px 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* HEADER */
  .header {
    background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 100%);
    padding: 32px 24px 28px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .header-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 900;
  }

  .header-sub {
    font-size: 13px;
    opacity: 0.75;
    margin-top: 4px;
  }

  .stats-row {
    display: flex;
    gap: 12px;
  }

  .stat-box {
    text-align: center;
    background: rgba(255,255,255,0.15);
    border-radius: 12px;
    padding: 10px 20px;
    min-width: 64px;
  }

  .stat-num {
    font-size: 24px;
    font-weight: 900;
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    opacity: 0.8;
    margin-top: 3px;
  }

  /* MAIN */
  .main {
    max-width: 760px;
    margin: 0 auto;
    padding: 24px 16px 60px;
  }

  /* CONTROLS */
  .controls {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
  }

  .filter-group {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-btn {
    background: #1a1a1a;
    color: var(--white);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
  }

  .filter-btn:hover { border-color: var(--teal); color: var(--teal); }
  .filter-btn.active { background: var(--teal); border-color: var(--teal); color: white; }

  .generate-btn {
    background: linear-gradient(135deg, var(--blue), #1d4ed8);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: opacity 0.2s;
  }

  .generate-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .spinner {
    width: 13px;
    height: 13px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    display: none;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* TWEET CARDS */
  .tweets-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .tweet-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 20px;
    transition: all 0.2s;
  }

  .tweet-card.posted {
    background: var(--card-posted);
    border-color: #1a2a1a;
    opacity: 0.6;
  }

  .tweet-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    gap: 10px;
  }

  .tweet-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 20px;
  }

  .tweet-badge.queued {
    color: var(--teal);
    background: rgba(13,148,136,0.1);
    border: 1px solid rgba(13,148,136,0.25);
  }

  .tweet-badge.posted {
    color: var(--green);
    background: rgba(22,163,74,0.1);
    border: 1px solid rgba(22,163,74,0.25);
  }

  .tweet-charcount {
    font-size: 11px;
    color: var(--mid);
  }

  .tweet-text {
    font-size: 14px;
    line-height: 1.75;
    color: #ddd;
    white-space: pre-wrap;
    margin-bottom: 14px;
    word-break: break-word;
  }

  .tweet-text.clamped {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .expand-btn {
    background: none;
    border: none;
    color: var(--teal);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    padding: 0 0 12px;
    display: block;
  }

  .tweet-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }

  .btn {
    border-radius: 7px;
    padding: 7px 14px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
    border: 1px solid transparent;
  }

  .btn-copy {
    background: #1e1e1e;
    color: var(--white);
    border-color: var(--border-light);
  }

  .btn-copy:hover, .btn-copy.copied {
    background: var(--teal);
    border-color: var(--teal);
  }

  .btn-edit {
    background: #1e1e1e;
    color: var(--light);
    border-color: var(--border-light);
  }

  .btn-edit:hover { border-color: #555; color: white; }

  .btn-posted {
    background: rgba(22,163,74,0.1);
    color: var(--green);
    border-color: rgba(22,163,74,0.3);
  }

  .btn-posted:hover { background: rgba(22,163,74,0.2); }

  .btn-unmark {
    background: #1e1e1e;
    color: var(--light);
    border-color: var(--border-light);
  }

  .btn-delete {
    background: rgba(239,68,68,0.08);
    color: var(--red);
    border-color: rgba(239,68,68,0.2);
    margin-left: auto;
  }

  .btn-delete:hover { background: rgba(239,68,68,0.15); }

  /* EDIT MODE */
  .edit-area {
    width: 100%;
    background: #0a0a0a;
    border: 1.5px solid var(--teal);
    border-radius: 8px;
    padding: 12px;
    color: var(--white);
    font-size: 14px;
    line-height: 1.7;
    resize: vertical;
    min-height: 120px;
    font-family: inherit;
    margin-bottom: 10px;
  }

  .edit-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .char-counter {
    font-size: 12px;
    color: var(--mid);
  }

  .char-counter.warn { color: #f59e0b; }
  .char-counter.over { color: var(--red); }

  .edit-btns { display: flex; gap: 8px; }

  .btn-save {
    background: var(--teal);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 7px 16px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
  }

  .btn-cancel {
    background: #222;
    color: var(--light);
    border: none;
    border-radius: 6px;
    padding: 7px 14px;
    font-size: 13px;
    cursor: pointer;
    font-family: inherit;
  }

  /* EMPTY STATE */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--mid);
  }

  .empty-state .emoji { font-size: 36px; margin-bottom: 12px; }
  .empty-state p { font-size: 15px; }

  /* TOAST */
  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--teal);
    color: white;
    padding: 12px 24px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    z-index: 999;
    transition: transform 0.3s ease;
    pointer-events: none;
  }

  .toast.show { transform: translateX(-50%) translateY(0); }

  @media (max-width: 600px) {
    .lock-card { padding: 36px 24px; }
    .header { padding: 24px 16px; }
    .header h1 { font-size: 22px; }
    .stat-box { padding: 8px 14px; min-width: 54px; }
    .stat-num { font-size: 20px; }
    .controls { flex-direction: column; align-items: stretch; }
    .generate-btn { justify-content: center; }
  }
</style>
</head>
