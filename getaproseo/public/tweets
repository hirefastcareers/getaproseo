let tweets = [];
let currentFilter = 'all';
let expandedIds = new Set();

// PASSWORD
function checkPassword() {
  const val = document.getElementById('password-input').value;
  if (val === PASSWORD) {
    sessionStorage.setItem('gapseo-auth', '1');
    document.getElementById('lock-screen').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    init();
  } else {
    document.getElementById('lock-error').style.display = 'block';
    document.getElementById('password-input').value = '';
    document.getElementById('password-input').focus();
  }
}

document.getElementById('password-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') checkPassword();
});

// AUTO-UNLOCK IF SESSION ACTIVE
if (sessionStorage.getItem('gapseo-auth') === '1') {
  document.getElementById('lock-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  init();
}

function init() {
  const stored = localStorage.getItem(STORAGE_KEY);
  if (stored) {
    tweets = JSON.parse(stored);
  } else {
    tweets = INITIAL_TWEETS.map((text, i) => ({
      id: i + 1,
      text,
      status: 'queued',
      created: new Date().toISOString()
    }));
    save();
  }
  render();
}

function save() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(tweets));
}

function setFilter(f) {
  currentFilter = f;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('filter-' + f).classList.add('active');
  render();
}

function render() {
  const total = tweets.length;
  const queued = tweets.filter(t => t.status === 'queued').length;
  const posted = tweets.filter(t => t.status === 'posted').length;

  document.getElementById('stat-total').textContent = total;
  document.getElementById('stat-queued').textContent = queued;
  document.getElementById('stat-posted').textContent = posted;
  document.getElementById('count-all').textContent = total;
  document.getElementById('count-queued').textContent = queued;
  document.getElementById('count-posted').textContent = posted;

  const filtered = tweets.filter(t => currentFilter === 'all' || t.status === currentFilter);
  const list = document.getElementById('tweets-list');
  const empty = document.getElementById('empty-state');

  if (filtered.length === 0) {
    list.innerHTML = '';
    empty.style.display = 'block';
    return;
  }

  empty.style.display = 'none';
  list.innerHTML = filtered.map((tweet, idx) => {
    const globalIdx = tweets.indexOf(tweet);
    const isExpanded = expandedIds.has(tweet.id);
    const needsClamp = tweet.text.length > 200;
    return `
      <div class="tweet-card ${tweet.status === 'posted' ? 'posted' : ''}" id="card-${tweet.id}">
        <div class="tweet-card-header">
          <span class="tweet-badge ${tweet.status}">${tweet.status === 'posted' ? '✓ Posted' : '#' + (globalIdx + 1) + ' Queued'}</span>
          <span class="tweet-charcount">${tweet.text.length}/280</span>
        </div>
        <div id="view-${tweet.id}">
          <p class="tweet-text ${needsClamp && !isExpanded ? 'clamped' : ''}" id="text-${tweet.id}">${escHtml(tweet.text)}</p>
          ${needsClamp ? `<button class="expand-btn" onclick="toggleExpand(${tweet.id})">${isExpanded ? 'Show less ↑' : 'Show more ↓'}</button>` : ''}
          <div class="tweet-actions">
            <button class="btn btn-copy" id="copy-${tweet.id}" onclick="copyTweet(${tweet.id})">Copy</button>
            <button class="btn btn-edit" onclick="startEdit(${tweet.id})">Edit</button>
            ${tweet.status === 'queued'
              ? `<button class="btn btn-posted" onclick="markPosted(${tweet.id})">✓ Mark Posted</button>`
              : `<button class="btn btn-unmark" onclick="markQueued(${tweet.id})">Unmark</button>`
            }
            <button class="btn btn-delete" onclick="deleteTweet(${tweet.id})">Delete</button>
          </div>
        </div>
        <div id="edit-${tweet.id}" style="display:none;">
          <textarea class="edit-area" id="edit-area-${tweet.id}" maxlength="280" oninput="updateCounter(${tweet.id})">${escHtml(tweet.text)}</textarea>
          <div class="edit-footer">
            <span class="char-counter" id="counter-${tweet.id}">${tweet.text.length}/280</span>
            <div class="edit-btns">
              <button class="btn-cancel" onclick="cancelEdit(${tweet.id})">Cancel</button>
              <button class="btn-save" onclick="saveEdit(${tweet.id})">Save</button>
            </div>
          </div>
        </div>
      </div>
    `;
  }).join('');
}

function escHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function toggleExpand(id) {
  if (expandedIds.has(id)) expandedIds.delete(id);
  else expandedIds.add(id);
  render();
}

function copyTweet(id) {
  const tweet = tweets.find(t => t.id === id);
  if (!tweet) return;
  navigator.clipboard.writeText(tweet.text);
  const btn = document.getElementById('copy-' + id);
  if (btn) { btn.textContent = '✓ Copied!'; btn.classList.add('copied'); }
  setTimeout(() => { if (btn) { btn.textContent = 'Copy'; btn.classList.remove('copied'); } }, 2000);
  showToast('Copied to clipboard!');
}

function markPosted(id) {
  tweets = tweets.map(t => t.id === id ? { ...t, status: 'posted', postedAt: new Date().toISOString() } : t);
  save();
  render();
  showToast('Marked as posted ✓');
}

function markQueued(id) {
  tweets = tweets.map(t => t.id === id ? { ...t, status: 'queued', postedAt: null } : t);
  save();
  render();
}

function deleteTweet(id) {
  if (!confirm('Delete this tweet?')) return;
  tweets = tweets.filter(t => t.id !== id);
  save();
  render();
}

function startEdit(id) {
  document.getElementById('view-' + id).style.display = 'none';
  document.getElementById('edit-' + id).style.display = 'block';
  const area = document.getElementById('edit-area-' + id);
  area.focus();
  area.setSelectionRange(area.value.length, area.value.length);
}

function cancelEdit(id) {
  document.getElementById('view-' + id).style.display = 'block';
  document.getElementById('edit-' + id).style.display = 'none';
}

function updateCounter(id) {
  const area = document.getElementById('edit-area-' + id);
  const counter = document.getElementById('counter-' + id);
  const len = area.value.length;
  counter.textContent = len + '/280';
  counter.className = 'char-counter' + (len > 270 ? ' over' : len > 250 ? ' warn' : '');
}

function saveEdit(id) {
  const area = document.getElementById('edit-area-' + id);
  const newText = area.value.trim();
  if (!newText) return;
  tweets = tweets.map(t => t.id === id ? { ...t, text: newText } : t);
  save();
  render();
  showToast('Tweet updated');
}

async function generateMore() {
  const btn = document.getElementById('generate-btn');
  const spinner = document.getElementById('gen-spinner');
  const label = document.getElementById('gen-label');

  btn.disabled = true;
  spinner.style.display = 'block';
  label.textContent = 'Generating...';

  try {
    const res = await fetch('/api/generate-tweets', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({})
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed');

    const newTweets = data.tweets.map((text, i) => ({
      id: Date.now() + i,
      text,
      status: 'queued',
      created: new Date().toISOString()
    }));

    tweets = [...tweets, ...newTweets];
    save();
    setFilter('queued');
    showToast('10 new tweets generated ✦');
  } catch (e) {
    showToast('Generation failed — try again');
  }

  btn.disabled = false;
  spinner.style.display = 'none';
  label.textContent = '✦ Generate 10 More';
}

function showToast(msg) {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 2500);
}
</script>
</body>
</html>
